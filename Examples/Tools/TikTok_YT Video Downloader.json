  "endpoint_body": "",
  "agent_functions": [
    {
      "uid": "ss6rqr3",
      "name": "tiktok_downloader",
      "description": "Downloads TikTok videos given a URL and saves them to a specified output directory, with an optional custom filename.",
      "is_enabled": true,
      "is_deleted": false,
      "function_string": "import os\nimport json\nimport re\nimport subprocess\n\ndef download_tiktok_video(url: str, output_dir: str, name: str = \"\") -> str:\n    \"\"\"Download a TikTok video from the given URL and save it to the output directory.\n\n    Args:\n        url: The TikTok video URL to download.\n        output_dir: The directory path where the video will be saved.\n        name: Optional custom filename (without extension). If empty, uses video title.\n\n    Returns:\n        A JSON string with download result including file_path, title, uploader, duration, and file_size.\n    \"\"\"\n    import yt_dlp\n\n    if not url or not url.strip():\n        return json.dumps({\"success\": False, \"error\": \"No URL provided. Please provide a valid TikTok video URL.\"})\n\n    if \"tiktok.com\" not in url.lower():\n        return json.dumps({\"success\": False, \"error\": f\"Invalid URL: '{url}' does not appear to be a TikTok URL. Please provide a URL containing 'tiktok.com'.\"})\n\n    output_dir = output_dir.strip()\n    if not output_dir:\n        return json.dumps({\"success\": False, \"error\": \"No output directory provided.\"})\n\n    try:\n        os.makedirs(output_dir, exist_ok=True)\n    except Exception as e:\n        return json.dumps({\"success\": False, \"error\": f\"Failed to create output directory '{output_dir}': {str(e)}\"})\n\n    if name and name.strip():\n        safe_name = re.sub(r'[<>:\\\"/\\\\|?*]', '_', name.strip())\n        output_template = os.path.join(output_dir, f\"{safe_name}.%(ext)s\")\n    else:\n        output_template = os.path.join(output_dir, \"%(title)s.%(ext)s\")\n\n    ydl_opts = {\n        'outtmpl': output_template,\n        'format': 'best',\n        'noplaylist': True,\n        'quiet': True,\n        'no_warnings': True,\n    }\n\n    try:\n        with yt_dlp.YoutubeDL(ydl_opts) as ydl:\n            info = ydl.extract_info(url, download=True)\n            file_path = ydl.prepare_filename(info)\n\n            if not os.path.exists(file_path):\n                possible_ext = ['mp4', 'webm', 'mkv']\n                base = os.path.splitext(file_path)[0]\n                for ext in possible_ext:\n                    candidate = f\"{base}.{ext}\"\n                    if os.path.exists(candidate):\n                        file_path = candidate\n                        break\n\n            file_size = os.path.getsize(file_path) if os.path.exists(file_path) else 0\n            file_size_mb = round(file_size / (1024 * 1024), 2)\n\n            result = {\n                \"success\": True,\n                \"file_path\": file_path,\n                \"title\": info.get(\"title\", \"Unknown\"),\n                \"uploader\": info.get(\"uploader\", \"Unknown\"),\n                \"duration_seconds\": info.get(\"duration\", 0),\n                \"file_size_mb\": file_size_mb,\n            }\n            return json.dumps(result)\n    except Exception as e:\n        return json.dumps({\"success\": False, \"error\": f\"Download failed: {str(e)}\"})\n"
    },
    {
      "uid": "vmh7nn4",
      "name": "h264_encoder",
      "description": "Re-encodes a video file to H.264 (MP4) using ffmpeg for maximum compatibility. Accepts an input file path and optional output path.",
      "is_enabled": true,
      "is_deleted": false,
      "function_string": "import os\nimport json\nimport subprocess\nimport shutil\n\ndef encode_video_h264(input_path: str, output_path: str = \"\") -> str:\n    \"\"\"Re-encode a video file to H.264 codec in an MP4 container using ffmpeg.\n\n    This is useful for ensuring maximum playback compatibility across devices and platforms.\n\n    Args:\n        input_path: The full file path of the video to encode.\n        output_path: Optional output file path. If empty, the encoded file will be saved alongside the original with '_h264' appended to the filename.\n\n    Returns:\n        A JSON string with the encoding result including output file path, codec info, and file size.\n    \"\"\"\n    if not input_path or not input_path.strip():\n        return json.dumps({\"success\": False, \"error\": \"No input file path provided.\"})\n\n    input_path = input_path.strip()\n\n    if not os.path.exists(input_path):\n        return json.dumps({\"success\": False, \"error\": f\"Input file not found: '{input_path}'\"})\n\n    if not os.path.isfile(input_path):\n        return json.dumps({\"success\": False, \"error\": f\"Path is not a file: '{input_path}'\"})\n\n    # Check ffmpeg is available\n    ffmpeg_path = shutil.which(\"ffmpeg\")\n    if not ffmpeg_path:\n        return json.dumps({\"success\": False, \"error\": \"ffmpeg is not installed or not found in PATH. Please install ffmpeg to use H.264 encoding.\"})\n\n    # Determine output path\n    if output_path and output_path.strip():\n        out = output_path.strip()\n        # Ensure it ends with .mp4\n        if not out.lower().endswith('.mp4'):\n            out = os.path.splitext(out)[0] + '.mp4'\n    else:\n        base, _ = os.path.splitext(input_path)\n        out = f\"{base}_h264.mp4\"\n\n    # Ensure output directory exists\n    out_dir = os.path.dirname(out)\n    if out_dir:\n        try:\n            os.makedirs(out_dir, exist_ok=True)\n        except Exception as e:\n            return json.dumps({\"success\": False, \"error\": f\"Failed to create output directory: {str(e)}\"})\n\n    # Build ffmpeg command\n    cmd = [\n        ffmpeg_path,\n        '-i', input_path,\n        '-c:v', 'libx264',\n        '-preset', 'medium',\n        '-crf', '23',\n        '-c:a', 'aac',\n        '-b:a', '128k',\n        '-movflags', '+faststart',\n        '-y',\n        out\n    ]\n\n    try:\n        result = subprocess.run(\n            cmd,\n            capture_output=True,\n            text=True,\n            timeout=600  # 10 minute timeout for long videos\n        )\n\n        if result.returncode != 0:\n            error_msg = result.stderr[-1000:] if len(result.stderr) > 1000 else result.stderr\n            return json.dumps({\"success\": False, \"error\": f\"ffmpeg encoding failed (exit code {result.returncode}): {error_msg}\"})\n\n        if not os.path.exists(out):\n            return json.dumps({\"success\": False, \"error\": \"Encoding appeared to succeed but output file was not created.\"})\n\n        # Get file sizes\n        input_size = os.path.getsize(input_path)\n        output_size = os.path.getsize(out)\n        input_size_mb = round(input_size / (1024 * 1024), 2)\n        output_size_mb = round(output_size / (1024 * 1024), 2)\n\n        # Try to get duration via ffprobe\n        duration = None\n        ffprobe_path = shutil.which(\"ffprobe\")\n        if ffprobe_path:\n            try:\n                probe_cmd = [\n                    ffprobe_path,\n                    '-v', 'quiet',\n                    '-print_format', 'json',\n                    '-show_format',\n                    '-show_streams',\n                    out\n                ]\n                probe_result = subprocess.run(probe_cmd, capture_output=True, text=True, timeout=30)\n                if probe_result.returncode == 0:\n                    probe_data = json.loads(probe_result.stdout)\n                    duration = probe_data.get('format', {}).get('duration', None)\n                    if duration:\n                        duration = round(float(duration), 2)\n            except Exception:\n                pass\n\n        return json.dumps({\n            \"success\": True,\n            \"output_path\": out,\n            \"input_path\": input_path,\n            \"video_codec\": \"H.264 (libx264)\",\n            \"audio_codec\": \"AAC 128kbps\",\n            \"container\": \"MP4\",\n            \"preset\": \"medium\",\n            \"crf\": 23,\n            \"input_size_mb\": input_size_mb,\n            \"output_size_mb\": output_size_mb,\n            \"duration_seconds\": duration,\n            \"message\": f\"Video successfully encoded to H.264. Output saved to: {out}\"\n        })\n\n    except subprocess.TimeoutExpired:\n        return json.dumps({\"success\": False, \"error\": \"Encoding timed out after 10 minutes. The video may be too long or the system too slow.\"})\n    except Exception as e:\n        return json.dumps({\"success\": False, \"error\": f\"Encoding failed: {str(e)}\"})\n"
    }
