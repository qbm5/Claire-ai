  "description": "Jira Cloud project and issue management agent. Can create projects (software type with Scrum template), look up project keys by name, list all issues in a project (with optional type filter), and create issues/stories/subtasks with descriptions and parent linking. Uses Jira REST API v3. Requires JIRA_URL, JIRA_EMAIL, and JIRA_API_TOKEN environment variables.",
  "prompt": "{{Input}}",
  "system_prompt": "You are an assistant in charge of managing Jira Cloud projects and issues. You have access to the following tool functions:\n\n1. **create_project(name, key, lead_account_id)** — Creates a new Jira Software project using the Scrum template. You must provide a project name, a unique project key (uppercase, alphanumeric), and the Atlassian account ID of the project lead. Returns the new project's key and ID on success.\n\n2. **get_project_key(project_name)** — Looks up a Jira project by its name and returns the corresponding project key. Useful when the user refers to a project by name rather than key.\n\n3. **list_issues(project_key, issue_type)** — Lists all issues in a given project (identified by its project key). You can optionally filter by issue type (e.g., \"Story\", \"Task\", \"Bug\", \"Sub-task\", \"Epic\"). Returns a summary of each issue including its key, summary, status, and type.\n\n4. **create_issue(project_key, summary, issue_type, description, parent_key)** — Creates a new issue in the specified project. You must provide the project key, a summary (title), and the issue type (e.g., \"Story\", \"Task\", \"Bug\", \"Sub-task\", \"Epic\"). Optionally, you can include a description and a parent issue key (for linking subtasks to their parent story/task). Returns the created issue's key on success.\n\n### Guidelines:\n- When the user asks to create a project, use **create_project**. If they don't provide a key, generate a sensible uppercase key from the project name.\n- When the user references a project by name and you need its key, use **get_project_key** first.\n- When the user wants to see what issues exist, use **list_issues** with the appropriate project key and optional type filter.\n- When the user asks to create stories, tasks, bugs, subtasks, or epics, use **create_issue**. If creating subtasks, make sure to include the parent_key linking them to the parent issue.\n- Always confirm the results of operations back to the user with the relevant details (project key, issue key, etc.).\n- If an operation fails, report the error clearly and suggest corrective actions.",
  "model": "",
  "chatbot_id": "",
  "endpoint_url": "",
  "endpoint_method": 0,
  "endpoint_headers": "",
  "endpoint_body": "",
  "agent_functions": [
    {
      "uid": "2ck1bix",
      "name": "JiraTools",
      "description": "Jira Cloud project and issue management functions using REST API v3",
      "is_enabled": true,
      "is_deleted": false,
      "function_string": "import json\nimport re\n\n\ndef create_project(name: str, key: str, lead_account_id: str) -> str:\n    \"\"\"Create a new Jira Software project with Scrum template.\n\n    Args:\n        name: The project name (e.g. 'My New Project')\n        key: Unique project key, uppercase alphanumeric (e.g. 'MNP')\n        lead_account_id: Atlassian account ID of the project lead\n\n    Returns:\n        A message with the created project key and ID, or an error.\n    \"\"\"\n    import requests\n    if not JIRA_SITE or not JIRA_TOKEN or not JIRA_EMAIL:\n        return \"Error: JIRA_SITE, JIRA_EMAIL, and JIRA_TOKEN must be configured in Environment Variables.\"\n    url = f\"{JIRA_SITE.rstrip('/')}/rest/api/3/project\"\n    headers = {\"Content-Type\": \"application/json\", \"Accept\": \"application/json\"}\n    payload = {\n        \"key\": key.upper(),\n        \"name\": name,\n        \"projectTypeKey\": \"software\",\n        \"projectTemplateKey\": \"com.pyxis.greenhopper.jira:gh-simplified-scrum-classic\",\n        \"leadAccountId\": lead_account_id,\n    }\n    try:\n        resp = requests.post(url, json=payload, headers=headers, auth=(JIRA_EMAIL, JIRA_TOKEN), timeout=30)\n        if resp.status_code in (200, 201):\n            data = resp.json()\n            return f\"Project created successfully. Key: {data.get('key')}, ID: {data.get('id')}\"\n        return f\"Error creating project ({resp.status_code}): {resp.text}\"\n    except Exception as e:\n        return f\"Exception creating project: {str(e)}\"\n\n\ndef get_project_key(project_name: str) -> str:\n    \"\"\"Look up a Jira project key by its name.\n\n    Args:\n        project_name: The name of the project to search for\n\n    Returns:\n        The project key if found, or an error message.\n    \"\"\"\n    import requests\n    if not JIRA_SITE or not JIRA_TOKEN or not JIRA_EMAIL:\n        return \"Error: JIRA_SITE, JIRA_EMAIL, and JIRA_TOKEN must be configured in Environment Variables.\"\n    url = f\"{JIRA_SITE.rstrip('/')}/rest/api/3/project/search\"\n    headers = {\"Accept\": \"application/json\"}\n    try:\n        resp = requests.get(url, headers=headers, auth=(JIRA_EMAIL, JIRA_TOKEN), timeout=30)\n        if resp.status_code != 200:\n            return f\"Error fetching projects ({resp.status_code}): {resp.text}\"\n        projects = resp.json().get(\"values\", [])\n        for p in projects:\n            if p.get(\"name\", \"\").lower() == project_name.lower():\n                return f\"Project '{p['name']}' has key: {p['key']}\"\n        available = \", \".join([f\"{p['name']} ({p['key']})\" for p in projects]) or \"none\"\n        return f\"No project found with name '{project_name}'. Available projects: {available}\"\n    except Exception as e:\n        return f\"Exception looking up project: {str(e)}\"\n\n\ndef list_issues(project_key: str, issue_type: str = \"\") -> str:\n    \"\"\"List all issues in a Jira project, optionally filtered by issue type.\n\n    Args:\n        project_key: The project key (e.g. 'MNP')\n        issue_type: Optional issue type filter (e.g. 'Story', 'Task', 'Bug', 'Sub-task', 'Epic')\n\n    Returns:\n        A formatted list of issues, or an error message.\n    \"\"\"\n    import requests\n    if not JIRA_SITE or not JIRA_TOKEN or not JIRA_EMAIL:\n        return \"Error: JIRA_SITE, JIRA_EMAIL, and JIRA_TOKEN must be configured in Environment Variables.\"\n    jql = f\"project={project_key}\"\n    if issue_type:\n        jql += f\" AND issuetype='{issue_type}'\"\n    url = f\"{JIRA_SITE.rstrip('/')}/rest/api/3/search\"\n    headers = {\"Accept\": \"application/json\"}\n    params = {\"jql\": jql, \"maxResults\": 100, \"fields\": \"summary,status,issuetype,parent\"}\n    try:\n        resp = requests.get(url, headers=headers, params=params, auth=(JIRA_EMAIL, JIRA_TOKEN), timeout=30)\n        if resp.status_code != 200:\n            return f\"Error searching issues ({resp.status_code}): {resp.text}\"\n        data = resp.json()\n        issues = data.get(\"issues\", [])\n        if not issues:\n            return f\"No issues found in project {project_key}\" + (f\" with type '{issue_type}'\" if issue_type else \"\") + \".\"\n        result_lines = [f\"Found {len(issues)} issue(s) in {project_key}:\"]\n        for issue in issues:\n            fields = issue.get(\"fields\", {})\n            key = issue.get(\"key\", \"?\")\n            summary = fields.get(\"summary\", \"No summary\")\n            status = fields.get(\"status\", {}).get(\"name\", \"Unknown\")\n            itype = fields.get(\"issuetype\", {}).get(\"name\", \"Unknown\")\n            parent = fields.get(\"parent\", {})\n            parent_key = parent.get(\"key\", \"\") if parent else \"\"\n            line = f\"  - {key} [{itype}] {summary} (Status: {status})\"\n            if parent_key:\n                line += f\" (Parent: {parent_key})\"\n            result_lines.append(line)\n        return \"\\n\".join(result_lines)\n    except Exception as e:\n        return f\"Exception listing issues: {str(e)}\"\n\n\ndef create_issue(project_key: str, summary: str, issue_type: str, description: str = \"\", parent_key: str = \"\") -> str:\n    \"\"\"Create a new issue in a Jira project.\n\n    Args:\n        project_key: The project key (e.g. 'MNP')\n        summary: The issue title/summary\n        issue_type: The type of issue (e.g. 'Story', 'Task', 'Bug', 'Sub-task', 'Epic')\n        description: Optional description for the issue\n        parent_key: Optional parent issue key for subtasks (e.g. 'MNP-1')\n\n    Returns:\n        A message with the created issue key, or an error.\n    \"\"\"\n    import requests\n    if not JIRA_SITE or not JIRA_TOKEN or not JIRA_EMAIL:\n        return \"Error: JIRA_SITE, JIRA_EMAIL, and JIRA_TOKEN must be configured in Environment Variables.\"\n    url = f\"{JIRA_SITE.rstrip('/')}/rest/api/3/issue\"\n    headers = {\"Content-Type\": \"application/json\", \"Accept\": \"application/json\"}\n    payload = {\n        \"fields\": {\n            \"project\": {\"key\": project_key},\n            \"summary\": summary,\n            \"issuetype\": {\"name\": issue_type},\n        }\n    }\n    if description:\n        payload[\"fields\"][\"description\"] = {\n            \"version\": 1,\n            \"type\": \"doc\",\n            \"content\": [\n                {\n                    \"type\": \"paragraph\",\n                    \"content\": [{\"type\": \"text\", \"text\": description}],\n                }\n            ],\n        }\n    if parent_key:\n        payload[\"fields\"][\"parent\"] = {\"key\": parent_key}\n    try:\n        resp = requests.post(url, json=payload, headers=headers, auth=(JIRA_EMAIL, JIRA_TOKEN), timeout=30)\n        if resp.status_code in (200, 201):\n            data = resp.json()\n            return f\"Issue created successfully. Key: {data.get('key')}, ID: {data.get('id')}, Self: {data.get('self')}\"\n        return f\"Error creating issue ({resp.status_code}): {resp.text}\"\n    except Exception as e:\n        return f\"Exception creating issue: {str(e)}\"\n"
    }
  ],
